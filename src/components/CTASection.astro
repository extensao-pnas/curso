---
import { courseData } from '../data/course-data';

const {
  registrationStart,
  registrationEnd,
  resultDate,
} = courseData.registration;
---

<section aria-labelledby="cta-heading" class="mt-6 md:mt-8 w-full max-w-6xl mx-auto px-4 md:px-8">
  <h2 id="cta-heading" class="sr-only">Inscrições</h2>
  <div
    class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between
           bg-navy rounded-lg px-6 py-4 md:px-8 animate-fade-in-up motion-reduce:animate-none motion-reduce:opacity-100"
  >
    <p class="text-white/90 font-semibold text-sm md:text-base leading-relaxed">
      <span aria-hidden="true">✦</span> <span class="text-gold font-bold">
        Inscrições gratuitas
      </span>
      &middot; {registrationStart} a {registrationEnd}
      &middot; Resultado: {resultDate}
    </p>

    <a
      href="https://forms.gle/jZsH9v4jt3G1L8zq5"
      target="_blank" rel="noopener noreferrer"
      class="group inline-flex items-center justify-center
             bg-gold text-navy font-bold text-sm
             px-6 py-2.5 rounded-md
             hover:bg-gold-light hover:scale-105
             transition-all duration-300
             flex-shrink-0 whitespace-nowrap"
    >
      Inscreva-se
      <span class="ml-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

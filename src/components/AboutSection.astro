---
import { courseData } from '../data/course-data';
---

<section aria-labelledby="about-heading" id="sobre" class="relative bg-cream overflow-hidden">
  <!-- Decorative subtle circle accents -->
  <div class="absolute -top-40 -right-40 size-96 rounded-full bg-navy/5 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-1/3 -left-20 size-72 rounded-full bg-gold/10 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-10 size-56 rounded-full bg-burgundy/5 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-1/2 right-1/4 size-24 rounded-full bg-navy/5 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-24">
    <!-- Heading -->
    <h2 id="about-heading" class="font-heading font-black text-2xl md:text-3xl text-navy mb-6 animate-fade-in-up motion-reduce:animate-none motion-reduce:opacity-100">
      Sobre o Curso
    </h2>

    <!-- Description -->
    <p class="text-navy/80 leading-relaxed text-base md:text-lg max-w-3xl mb-12 animate-fade-in-up animate-delay-200 motion-reduce:animate-none motion-reduce:opacity-100">
      {courseData.aboutText}
    </p>

    <!-- Highlight Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Card 1 — Workload -->
      <div class="flex flex-col items-center text-center bg-white rounded-lg shadow-sm p-6 md:p-8 card-hover animate-fade-in-up animate-delay-300 motion-reduce:animate-none motion-reduce:opacity-100">
        <svg class="w-10 h-10 md:w-12 md:h-12 text-gold mb-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <strong class="font-heading font-bold text-lg text-navy">
          {courseData.schedule.workload}
        </strong>
        <span class="text-gray text-sm mt-1">Carga horária total</span>
      </div>

      <!-- Card 2 — Format -->
      <div class="flex flex-col items-center text-center bg-white rounded-lg shadow-sm p-6 md:p-8 card-hover animate-fade-in-up animate-delay-400 motion-reduce:animate-none motion-reduce:opacity-100">
        <svg class="w-10 h-10 md:w-12 md:h-12 text-gold mb-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="2" y1="20" x2="22" y2="20"/>
        </svg>
        <strong class="font-heading font-bold text-lg text-navy">
          {courseData.schedule.format}
        </strong>
        <span class="text-gray text-sm mt-1">Formato online</span>
      </div>

      <!-- Card 3 — Schedule day & time -->
      <div class="flex flex-col items-center text-center bg-white rounded-lg shadow-sm p-6 md:p-8 card-hover animate-fade-in-up animate-delay-500 motion-reduce:animate-none motion-reduce:opacity-100">
        <svg class="w-10 h-10 md:w-12 md:h-12 text-gold mb-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <strong class="font-heading font-bold text-lg text-navy">
          {courseData.period.day}
        </strong>
        <span class="text-gray text-sm mt-1">{courseData.schedule.time}</span>
      </div>
    </div>
  </div>
</section>

---
import { courseData } from '../data/course-data';
---

<section aria-labelledby="selection-criteria-heading" class="max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-20">
  <h2 id="selection-criteria-heading" class="font-heading font-black text-2xl md:text-3xl text-navy mb-8 animate-fade-in-up motion-reduce:animate-none motion-reduce:opacity-100">
    Critérios de Seleção
  </h2>

  <div class="space-y-4">
    {
      courseData.criteria.map((criterion, i) => (
        <div
          class="group flex items-start gap-4 rounded-lg border-l-4 border-gold/30 bg-white/60 p-5 transition-all duration-300 hover:border-gold hover:bg-white/90 hover:translate-x-1 animate-fade-in-up motion-reduce:animate-none motion-reduce:opacity-100"
          style={`animation-delay: ${200 + i * 100}ms`}
        >
          <!-- Gold checkmark circle -->
          <span
            class="bg-gold text-navy rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0 mt-0.5"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="w-3.5 h-3.5"
            >
              <path
                fill-rule="evenodd"
                d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                clip-rule="evenodd"
              />
            </svg>
          </span>

          <!-- Criterion text -->
          <p class="text-navy/80 text-base leading-relaxed">
            {criterion}
          </p>
        </div>
      ))
    }
  </div>
</section>

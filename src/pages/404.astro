---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada — Curso de Extensão SUAS 2026">
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
    <span
      class="text-8xl md:text-9xl font-black text-gold/20 font-heading select-none"
      aria-hidden="true"
    >
      404
    </span>
    <h1 class="font-heading font-black text-3xl md:text-4xl text-navy mt-4">
      Página não encontrada
    </h1>
    <p class="text-gray mt-4 max-w-md">
      A página que você procura não existe ou foi movida. Volte para a página
      principal do curso.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 bg-gold text-navy font-bold px-6 py-3 rounded-md hover:bg-gold-light transition-colors duration-200"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 8L7 4M3 8L7 12M3 8H13"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        />
      </svg>
      Voltar ao início
    </a>
  </div>
</BaseLayout>
